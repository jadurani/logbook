---
interface Props {
  type?: 'note' | 'tip' | 'warning';
}
const { type = 'note' } = Astro.props;

const borderClass = {
  note: 'border-accent-mid',
  tip: 'border-zone-photic',
  warning: 'border-zone-aphotic',
}[type];

const labelClass = {
  note: 'text-accent-mid',
  tip: 'text-zone-photic',
  warning: 'text-zone-aphotic',
}[type];
---
<div class:list={['not-prose border-l-2 bg-surface pl-4 py-3 pr-4 my-6 rounded-r', borderClass]}>
  <p class:list={['text-xs uppercase tracking-widest mb-2 font-semibold', labelClass]}>{type}</p>
  <slot />
</div>
